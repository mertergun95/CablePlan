<Window x:Class="CablePlan.CableAssignmentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kabel zuordnen"
        Height="520"
        Width="620"
        MinWidth="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanMinimize"
        Background="#F7F7F7">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="Kabel-Zuordnung"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#222"/>
            <TextBlock x:Name="TxtSperrpauseHeader"
                       Text="Sperrpause: -"
                       Margin="0,6,0,0"
                       Foreground="#444"
                       FontWeight="SemiBold"
                       TextWrapping="Wrap"/>
            <TextBlock Text="Wähle die Kabel aus, die dieser Sperrpause zugeordnet sind."
                       Margin="0,6,0,0"
                       Foreground="#666"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Kabel suchen"
                       FontWeight="Bold"
                       Margin="0,0,0,4"/>
            <TextBox x:Name="TxtSearch"
                     Height="28"
                     VerticalContentAlignment="Center"/>
        </StackPanel>

        <Border Grid.Row="2"
                BorderBrush="#D0D0D0"
                BorderThickness="1"
                Background="White"
                CornerRadius="6"
                Padding="6">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ItemsPanel"/>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <Button x:Name="BtnSelectAll"
                        Content="Alle"
                        Width="80"
                        Height="30"
                        Margin="0,0,8,0"/>
                <Button x:Name="BtnClearAll"
                        Content="Keine"
                        Width="80"
                        Height="30"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" DockPanel.Dock="Right">
                <Button x:Name="BtnCancel"
                        Content="Abbrechen"
                        Width="100"
                        Height="32"
                        Margin="0,0,8,0"/>
                <Button x:Name="BtnSave"
                        Content="Speichern"
                        Width="100"
                        Height="32"
                        FontWeight="Bold"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</Window>
