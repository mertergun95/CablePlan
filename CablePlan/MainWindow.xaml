<Window x:Class="CablePlan.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Kabel-Lageplan – Markierung"
        Width="1520" Height="980"
        WindowState="Maximized"
        Background="#1F2430">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4C5D7A"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#6E7F9C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A6E91"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#8EA1C2"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E4F6A"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Background" Value="#3E4C66"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#6E7F9C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#8A6FD1"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#B7A2EA"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#5A6E91"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2A3142"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#5F7090"/>
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#2A3142"/>
            <Setter Property="Foreground" Value="#F5F7FB"/>
            <Setter Property="BorderBrush" Value="#5F7090"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E4EAF7"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="440" />
        </Grid.ColumnDefinitions>

        <!-- VIEWER -->
        <Border Grid.Column="0" Background="#111">
            <ScrollViewer x:Name="PdfScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          CanContentScroll="False"
                          PreviewMouseWheel="PdfScroll_PreviewMouseWheel"
                          PreviewMouseDown="PdfScroll_PreviewMouseDown"
                          PreviewMouseUp="PdfScroll_PreviewMouseUp"
                          PreviewMouseMove="PdfScroll_PreviewMouseMove"
                          PreviewMouseLeftButtonDown="PdfScroll_PreviewMouseLeftButtonDown">

                <Grid x:Name="ContentRoot">
                    <Grid.LayoutTransform>
                        <ScaleTransform x:Name="ZoomTf" ScaleX="1" ScaleY="1"/>
                    </Grid.LayoutTransform>

                    <Image x:Name="PlanImage"
                           Stretch="None"
                           SnapsToDevicePixels="True"
                           RenderOptions.BitmapScalingMode="HighQuality"/>

                    <Canvas x:Name="Overlay"
                            IsHitTestVisible="True"
                            Background="Transparent"/>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- RIGHT PANEL -->
        <Border Grid.Column="1" Background="#242B3B" BorderBrush="#3A4358" BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="12" VerticalAlignment="Top">

                    <TextBlock Text="Workspace" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtWorkspacePath" Text="-" Foreground="#C8D4ED" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button x:Name="BtnOpenWorkspaceFolder" Content="Ordner öffnen" Height="30" Width="150" Margin="0,0,8,0"/>
                        <Button x:Name="BtnChooseWorkspace" Content="Workspace wechseln" Height="30" Width="150"/>
                    </StackPanel>

                    <Separator Margin="0,12"/>

                    <TextBlock Text="PDF-Bibliothek" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnImportPdf" Content="PDF importieren" Height="32" Width="150" Margin="0,0,8,0"/>
                        <Button x:Name="BtnOpenSelectedPdf" Content="PDF öffnen" Height="32" Width="120"/>
                    </StackPanel>
                    <ListBox x:Name="LstPdfs" Height="180" Margin="0,8,0,0"/>

                    <Separator Margin="0,12"/>

                    <TextBlock Text="Ansicht" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <TextBlock x:Name="TxtMode" Text="Modus: Ansicht" FontWeight="Bold" Foreground="#E8F0FF" Margin="0,0,0,8"/>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="BtnFitWidth" Content="An Breite anpassen" Height="32" Width="170" Margin="0,0,8,0"/>
                        <Button x:Name="BtnFitPage" Content="An Seite anpassen" Height="32" Width="150"/>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnRotateLeft" Content="↺ 90°" Width="90" Height="30" Margin="0,0,8,0"/>
                        <Button x:Name="BtnRotateRight" Content="↻ 90°" Width="90" Height="30" Margin="0,0,8,0"/>
                        <TextBlock Text="Rotation:" VerticalAlignment="Center" Margin="10,0,4,0"/>
                        <TextBlock x:Name="TxtRotation" Text="0°" VerticalAlignment="Center" FontWeight="Bold"/>
                    </StackPanel>

                    <TextBlock Margin="0,8,0,0" Foreground="#B8C6E6"
                               Text="Pan: mittlere Maustaste halten &amp; ziehen. Zoom: Mausrad. ESC=Abbrechen. Enter=Speichern."/>

                    <UniformGrid Columns="3" Margin="0,10,0,0">
                        <Button x:Name="BtnExportPng" Content="Ansicht als PNG" Height="30" Margin="0,0,6,0"/>
                        <Button x:Name="BtnExportPdf" Content="Ansicht als PDF" Height="30" Margin="0,0,6,0"/>
                        <Button x:Name="BtnPrintView" Content="Drucken" Height="30"/>
                    </UniformGrid>

                    <Separator Margin="0,12"/>

                    <Expander x:Name="ExpDrawPanel"
                              Header="Zeichnen"
                              IsExpanded="False"
                              Foreground="#E4EAF7"
                              Margin="0,0,0,0">
                        <StackPanel Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <ToggleButton x:Name="TglDrawCable" Content="Kabel zeichnen" Width="130" Height="30" Margin="0,0,8,0"/>
                                <ToggleButton x:Name="TglDrawSperrpause" Content="Sperrpause zeichnen" Width="150" Height="30" Margin="0,0,8,0"/>
                                <ToggleButton x:Name="TglSetLabel" Content="Beschriftung" Width="100" Height="30"/>
                            </StackPanel>

                            <TextBlock Text="Kabel-ID" FontWeight="Bold" Margin="0,12,0,6"/>
                            <TextBox x:Name="TxtCableId" Height="28"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="BtnFinishCable" Content="Kabel speichern" Height="30" Width="150" Margin="0,0,8,0"/>
                                <Button x:Name="BtnDeleteCable" Content="Kabel löschen" Height="30" Width="120"/>
                            </StackPanel>

                            <TextBlock Text="Sperrpause-ID" FontWeight="Bold" Margin="0,12,0,6"/>
                            <TextBox x:Name="TxtSperrpauseId" Height="28"/>

                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="BtnFinishSperrpause" Content="Sperrpause speichern" Height="30" Width="170" Margin="0,0,8,0"/>
                                <Button x:Name="BtnDeleteSperrpause" Content="Sperrpause löschen" Height="30" Width="150"/>
                            </StackPanel>

                            <Button x:Name="BtnCancel" Content="Abbrechen" Height="30" Width="120" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Expander>

                    <Separator Margin="0,14"/>

                    <TextBlock Text="Global: Kabel suchen (über alle PDFs)" FontWeight="Bold" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtGlobalCableSearch" Height="28"/>
                    <ListBox x:Name="LstGlobalCables" Height="160" Margin="0,8,0,0"/>

                    <Separator Margin="0,14"/>

                    <DockPanel Margin="0,0,0,6">
                        <TextBlock Text="Dieses PDF: Kabel-Liste"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   DockPanel.Dock="Left"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button x:Name="BtnClearCableSelection"
                                    Content="Auswahl löschen"
                                    Width="110"
                                    Height="24"
                                    Margin="0,0,8,0"/>
                            <ToggleButton x:Name="TglMultiSelect"
                                          Content="Multi"
                                          Width="70"
                                          Height="24"/>
                        </StackPanel>
                    </DockPanel>

                    <TextBox x:Name="TxtSearch" Height="28"/>

                    <ListBox x:Name="LstCables"
                         Height="170"
                         Margin="0,8,0,0"
                         SelectionMode="Single">    
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="PreviewMouseRightButtonDown"
                                     Handler="LstCablesItem_PreviewMouseRightButtonDown"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem x:Name="MiAssignSperrpause"
                                                Header="Sperrpause zuweisen"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <Separator Margin="0,14"/>

                    <StackPanel Margin="0,0,0,6">
                        <TextBlock Text="Sperrpausen-Filter"
                                   FontWeight="Bold"
                                   Margin="0,0,0,6"/>
                        <WrapPanel>
                            <ToggleButton x:Name="TglSperrBasedCableFilter"
                                          Content="Sperr → Kabel"
                                          MinWidth="120"
                                          Height="24"
                                          Margin="0,0,8,6"/>
                            <ToggleButton x:Name="TglCableBasedSperrFilter"
                                          Content="Kabel → Sperr"
                                          MinWidth="110"
                                          Height="24"
                                          IsChecked="True"
                                          Margin="0,0,8,6"/>
                            <Button x:Name="BtnClearSperrFilter"
                                    Content="Filter leeren"
                                    MinWidth="100"
                                    Height="24"
                                    Margin="0,0,0,6"/>
                        </WrapPanel>
                    </StackPanel>

                    <TextBlock x:Name="TxtSperrFilterInfo"
                               Text="Alle Sperrpausen sichtbar"
                               Foreground="#B8C6E6"
                               Margin="0,0,0,6"/>

                    <TextBox x:Name="TxtSperrSearch" Height="28"/>

                    <ListBox x:Name="LstSperrpauses"
                             Height="170"
                             Margin="0,8,0,0"
                             SelectionMode="Extended">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <EventSetter Event="PreviewMouseLeftButtonDown"
                                             Handler="LstSperrpausesItem_PreviewMouseLeftButtonDown"/>
                                <EventSetter Event="PreviewMouseRightButtonDown"
                                             Handler="LstSperrpausesItem_PreviewMouseRightButtonDown"/>
                                <Setter Property="ContextMenu">
                                    <Setter.Value>
                                        <ContextMenu>
                                            <MenuItem x:Name="MiAssignCablesToSperrpause"
                                                      Header="Kabel zuordnen"/>
                                        </ContextMenu>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
